# Server-side keys for Next route handlers
FRED_API_KEY=your_fred_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest
EDGAR_USER_AGENT=OpenAlpha dev@openalpha.io
# Optional. Enables Finnhub news. Falls back to Yahoo Finance if not set.
FINNHUB_API_KEY=
REQUEST_QUOTA_SIGNING_SECRET=replace_with_a_long_random_secret
REQUEST_OVERRIDE_PASSWORD=replace_with_your_private_override_password
QUOTA_ENABLED=true
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: keep these only while migrating any still-external routes.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# INTERNAL_API_URL=http://backend:8000
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Firebase browser SDK configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
