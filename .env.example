# Mistral AI (required -- only paid dependency)
MISTRAL_API_KEY=your_mistral_api_key_here

# FRED API (free: https://fred.stlouisfed.org/docs/api/fred/)
FRED_API_KEY=your_fred_api_key_here

# SEC EDGAR requires a User-Agent string (SEC policy)
EDGAR_USER_AGENT=YourName your@email.com

# Backend CORS (comma-separated origins)
BACKEND_CORS_ORIGINS=http://localhost:3000
